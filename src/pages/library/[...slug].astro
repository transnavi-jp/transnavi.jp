---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const pages = await getCollection('imported');
  return pages.map((page) => ({ params: { slug: page.id }, props: { page } }));
}

const { page } = Astro.props;
const { Content, headings } = await render(page);

const toc = headings.filter((heading) => heading.depth === 2 && heading.slug);
const importedAt = new Intl.DateTimeFormat('ja-JP', { dateStyle: 'medium' }).format(page.data.importedAt);
const isMedical = page.data.sourceCategory?.includes('医療') ?? false;

// Sibling pages in the same imported folder, for forward/back wayfinding.
const all = await getCollection('imported');
const dirOf = (id: string) => id.split('/').slice(0, -1).join('/');
const siblings = all
  .filter((other) => other.id !== page.id && dirOf(other.id) === dirOf(page.id))
  .sort((a, b) => a.data.title.localeCompare(b.data.title, 'ja'));
---

<BaseLayout title={`${page.data.title} - とらんすナビ`} description={page.data.description}>
  <article class="article-shell">
    <div class="eyebrow">{page.data.sourceCategory}</div>
    <h1>{page.data.title}</h1>
    <aside class="import-notice" role="note" aria-label="このページについて">
      <p>
        <strong>これは「取り込み記事」です。</strong>{page.data.sourceProject} の記事を、当サイトが日本語に翻訳・再構成（抄訳）したものです。当サイトが一から書いた解説ではなく、原文の内容や、翻訳・編集の過程に由来する誤りが含まれることがあります。
      </p>
      <p>
        {page.data.ownPage && (<>同じテーマの<a href={page.data.ownPage}><strong>当サイト自身の解説</strong></a>もあります。まずはそちらをどうぞ。{' '}</>)}
        原文（{page.data.sourceUrl
          ? <a href={page.data.sourceUrl} target="_blank" rel="noreferrer">{page.data.sourceProject}</a>
          : page.data.sourceProject}、{page.data.sourceLicense.split('（')[0]}）と読み比べられます。
        {isMedical && ' 内容が最新・正確とはかぎりません。治療やお薬のことは、必ず医師に相談してください。'}
      </p>
    </aside>

    <div class="article-meta">
      <span class="pill">出典: {page.data.sourceUrl
        ? <a href={page.data.sourceUrl} target="_blank" rel="noreferrer">{page.data.sourceProject}</a>
        : page.data.sourceProject}</span>
      <span class="pill">取り込み: {importedAt}</span>
      <span class="pill">確認: 要確認</span>
    </div>

    {page.data.editNotes && page.data.editNotes.length > 0 && (
      <details class="import-editnotes">
        <summary>当サイトによる主な変更・注記（原文との違い）</summary>
        <p>この記事は原文そのままではありません。日本語への翻訳・再構成にくわえ、当サイトが次の修正・編集を加えています。{isMedical && '（自己投薬の手順・入手先・価格などは省いています。）'}これら以外の内容は、原文に由来します。</p>
        <ul>
          {page.data.editNotes.map((note) => <li>{note}</li>)}
        </ul>
      </details>
    )}

    {toc.length > 2 && (
      <nav class="toc" aria-label="目次">
        <p class="toc-title">目次</p>
        <ul>
          {toc.map((heading) => (
            <li><a href={`#${heading.slug}`}>{heading.text}</a></li>
          ))}
        </ul>
      </nav>
    )}

    <div class="prose">
      <Content />
    </div>

    {siblings.length > 0 && (
      <nav class="word-chips entry-related" aria-label="関連ページ">
        {siblings.map((other) => (
          <a class="word-chip" href={`/library/${other.id}/`}>{other.data.title}</a>
        ))}
        <a class="word-chip" href="/clinics/">医療機関を探す</a>
      </nav>
    )}

    <section class="notice" aria-labelledby="source-info">
      <h2 id="source-info">出典</h2>
      <p>{page.data.sourcePath} から取り込みました。出典元のライセンスは {page.data.sourceLicense} です。</p>
    </section>
  </article>
</BaseLayout>
