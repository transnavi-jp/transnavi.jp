---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const pages = (await getCollection('imported')).sort((a, b) => a.data.title.localeCompare(b.data.title, 'ja'));

// Group by 出典 (source project), not by topic: each source is a different
// project with its own provenance, nature (faithful import vs. transnavi
// adaptation) and license, so keeping them in separate, clearly-labelled
// sections is what keeps the attribution honest as more sources are added.
const sources = [...new Set(pages.map((page) => page.data.sourceProject))];
const groups = sources.map((source) => {
  const items = pages.filter((page) => page.data.sourceProject === source);
  return { source, url: items[0]?.data.sourceUrl, license: items[0]?.data.sourceLicense ?? '', items };
});
---

<BaseLayout
  title="資料集 - とらんすナビ"
  description="ほかのプロジェクトの資料を、出典ごとに取り込み・整理したページです。それぞれの出典とライセンスを明記しています。"
>
  <article class="article-shell">
    <div class="eyebrow">資料集</div>
    <h1>資料集</h1>
    <p class="lead">
      ほかのプロジェクトがつくった資料を、出典ごとに取り込み・整理した<strong>アーカイブ</strong>です。当サイトが一から書いた解説ではありません。それぞれの出典とライセンスを明記しています。
    </p>

    <aside class="import-notice" role="note">
      <p>
        <strong>当サイトが書いた解説をお探しですか？</strong>　まずは<a href="/learn/">知る・学ぶ</a>や、各テーマのページ（<a href="/hrt-effects/">ホルモン療法で起きること</a>、<a href="/hrt-medications/">ホルモン療法の薬とフラホル</a>、<a href="/surgery/">移行のための手術</a>など）をどうぞ。下の資料は、外部の解説を取り込んだ<strong>参考用のアーカイブ</strong>です。
      </p>
    </aside>

    <div class="page-disclaimer">
      ここにある資料は、別のプロジェクトの文章を日本語に訳して再構成（抄訳）したものです。当サイトが書いた解説ではないため、原文や、翻訳・編集の過程に由来する誤りが含まれることがあります。各記事の冒頭に、当サイトが加えた変更点（原文との違い）を記しています。内容が最新・正確とはかぎりません。医療のことは、必ず医師に相談してください。
    </div>

    {groups.map((group, i) => (
      <section aria-labelledby={`src-${i}`}>
        <h2 id={`src-${i}`}>
          {group.url ? <a href={group.url} target="_blank" rel="noreferrer">{group.source}</a> : group.source}
        </h2>
        <p class="resource-section-intro">ライセンス: {group.license}</p>
        <div class="article-list">
          {group.items.map((page) => (
            <a class="article-link" href={`/library/${page.id}/`}>
              <strong>{page.data.title}</strong>
              <span>{page.data.sourceCategory}</span>
            </a>
          ))}
        </div>
      </section>
    ))}
  </article>
</BaseLayout>
