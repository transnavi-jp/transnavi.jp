---
import BaseLayout from '../../layouts/BaseLayout.astro';
import clinicsData from '../../data/clinics.json';
import type { Clinic } from '../../types/clinic';
import { categoriesOf, capabilitiesOf, CAPABILITY_LABELS, isGiCertified, isOverseas, type Capability } from '../../utils/clinic-genre';

const prefectureOrder = [
  '北海道', '青森県', '岩手県', '宮城県', '秋田県', '山形県', '福島県', '茨城県', '栃木県', '群馬県',
  '埼玉県', '千葉県', '東京都', '神奈川県', '新潟県', '富山県', '石川県', '福井県', '山梨県', '長野県',
  '岐阜県', '静岡県', '愛知県', '三重県', '滋賀県', '京都府', '大阪府', '兵庫県', '奈良県', '和歌山県',
  '鳥取県', '島根県', '岡山県', '広島県', '山口県', '徳島県', '香川県', '愛媛県', '高知県', '福岡県',
  '佐賀県', '長崎県', '熊本県', '大分県', '宮崎県', '鹿児島県', '沖縄県',
];

const all = clinicsData as Clinic[];
const surgery = all
  .map((clinic) => ({ ...clinic, caps: capabilitiesOf(clinic) }))
  .filter((clinic) => categoriesOf(clinic).includes('surgery') || clinic.caps.some((cap) => cap.startsWith('surgery')));

const byPrefecture = prefectureOrder
  .map((prefecture) => ({ prefecture, items: surgery.filter((clinic) => !isOverseas(clinic) && clinic.prefecture === prefecture) }))
  .filter((group) => group.items.length > 0);

// Overseas SRS/FFS hospitals (タイ・韓国), grouped by country and listed after Japan.
const overseasByCountry = [...new Set(surgery.filter(isOverseas).map((clinic) => clinic.prefecture))]
  .sort((a, b) => a.localeCompare(b, 'ja'))
  .map((country) => ({ country, items: surgery.filter((clinic) => clinic.prefecture === country) }));

const count = (cap: Capability) => surgery.filter((clinic) => clinic.caps.includes(cap)).length;

const faqs = [
  {
    q: '性別適合手術（SRS）は、日本のどこで受けられますか？',
    a: '専門の医療機関や、トランスジェンダーの手術に対応している一部の美容外科・大学病院などで受けられます。このページの地域別一覧や、地図から探せます。施設によって対応する術式（造腟・精巣摘出・乳房切除・顔の手術・声の手術など）が違うので、受けたい手術に対応しているか、予約の前に確認してください。',
  },
  {
    q: '性別適合手術に健康保険はききますか？',
    a: '性別適合手術は、日本GI（性別不合）学会が認定した施設で受ける場合にかぎり保険の対象になります。ただしホルモン療法を併用していると「混合診療」となって保険が使えなくなるため、今の制度では保険を使えるのは事実上ごく一部にかぎられます。くわしくは「お金のこと・費用の全体像」を読んでみてください。',
  },
  {
    q: '手術の費用はどれくらいですか？',
    a: '術式や施設によって大きく変わります。目安として、乳房切除（胸オペ）は70万円前後から、造腟を含む手術は200万〜250万円ほどなど、幅があります。あくまで目安なので、必ず各医療機関で確認してください。費用の全体像は「お金のこと・費用の全体像」にまとめています。',
  },
  {
    q: '手術はかならず受けないといけませんか？',
    a: 'いいえ。どの手術も必須ではありません。受けるか・受けないか、どの手術をどの順番でするかは、すべてあなたが選べます。手術の種類のオリエンテーションは「移行のための手術」へ。',
  },
];

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
};
---

<BaseLayout
  title="性別適合手術（SRS）ができる病院・クリニック一覧【MtF・FtM】 - とらんすナビ"
  description="日本で性別適合手術（SRS）や乳房切除（胸オペ）、顔の手術（FFS）、声の手術（VFS）などを受けられる病院・クリニックを地域別にまとめた一覧。費用や保険、受診前に確認したいことも。"
>
  <script type="application/ld+json" set:html={JSON.stringify(faqLd)} />
  <article class="article-shell">
    <div class="eyebrow">医療機関</div>
    <h1>性別適合手術（SRS）などができる病院・クリニック</h1>
    <p class="lead">
      性別適合手術（SRS）や乳房切除（胸オペ）、顔の手術（FFS）、声の手術（VFS）などに対応すると、公開情報で確認できた医療機関を地域別にまとめました。どの手術も必須ではありません。あなたのペースで、近くから探してみてください。
    </p>

    <div class="page-disclaimer">
      このページは、特定のクリニックをすすめたり、比べたりするものではありません。対応する術式・費用・条件は変わることがあります。実際に受けられるかどうかは、必ず各医療機関にご確認ください。
    </div>

    <div class="clinic-summary" aria-label="掲載件数">
      <span>手術に対応 <strong>{surgery.length}</strong> 件</span>
      <span>SRS {count('surgery-srs')} 件</span>
      <span>睾丸摘出術 {count('surgery-orchiectomy')} 件</span>
      <span>乳房切除 {count('surgery-mastectomy')} 件</span>
      <span>顔の手術（FFS）{count('surgery-ffs')} 件</span>
      <span>声の手術（VFS）{count('surgery-vfs')} 件</span>
      <span>豊胸 {count('surgery-breast')} 件</span>
    </div>

    <section aria-labelledby="how">
      <h2 id="how">手術ができる病院の探し方</h2>
      <ul class="assure-list">
        <li>受けたい手術（造腟・精巣摘出・乳房切除・<a href="/glossary/ffs/">顔の手術（FFS）</a>・<a href="/glossary/voice-feminization-surgery/">声の手術（VFS）</a>など）に対応しているか、予約のときに確認すると確実です。</li>
        <li>手術の種類とおおまかな流れは<a href="/surgery/">移行のための手術</a>、費用の目安は<a href="/cost/">お金のこと・費用の全体像</a>へ。</li>
        <li><strong>保険について：</strong>日本GI（性別不合）学会の認定施設なら保険の対象になりますが、ホルモン療法を併用していると混合診療となり、今の制度では使えるのは事実上ごく一部です（<a href="/transition/">性別移行を知る</a>）。</li>
        <li>地図から探したいときは<a href="/map/">地図で探す</a>、絞り込み・検索は<a href="/clinics/">医療機関の一覧（検索・絞り込み）</a>からどうぞ。</li>
      </ul>
    </section>

    <section aria-labelledby="list">
      <h2 id="list">手術に対応する医療機関（地域別）</h2>
      <p>
        各施設のタグは、公開情報で確認できた対応です。<strong>タグがないことは、対応していないという意味ではありません。</strong>
        <span class="clinic-tag clinic-tag-certified">GI学会認定施設</span>のしるしは、日本GI（性別不合）学会の認定施設（保険適用での性別適合手術が受けられる施設）を示します。網羅ではなく、最新の認定状況は<a href="http://www.gi-soc.jp/" target="_blank" rel="noreferrer">学会の一覧</a>でご確認ください。
      </p>
      {byPrefecture.map((group) => (
        <div class="finder-region">
          <h3 class="finder-region-name">{group.prefecture}</h3>
          <ul class="finder-clinic-list">
            {group.items.map((clinic) => (
              <li class="finder-clinic">
                <a href={`/clinics/${clinic.id}/`}>{clinic.name}</a>
                <span class="finder-clinic-city">{clinic.city}</span>
                {(clinic.caps.length > 0 || isGiCertified(clinic)) && (
                  <span class="finder-clinic-tags">
                    {isGiCertified(clinic) && (
                      <span class="clinic-tag clinic-tag-certified">GI学会認定施設</span>
                    )}
                    {clinic.caps.map((cap) => (
                      <span class:list={['clinic-tag', cap.startsWith('gaht') ? 'clinic-tag-gaht' : 'clinic-tag-surgery']}>
                        {CAPABILITY_LABELS[cap]}
                      </span>
                    ))}
                  </span>
                )}
              </li>
            ))}
          </ul>
        </div>
      ))}
      <p>
        絞り込みや検索（地域・診療区分・対応）をしたいときは、<a href="/clinics/">医療機関の一覧ページ</a>からどうぞ。
      </p>
    </section>

    {overseasByCountry.length > 0 && (
      <section aria-labelledby="overseas">
        <h2 id="overseas">海外で性別適合手術（SRS）・顔の女性化手術（FFS）を行う病院</h2>
        <p>
          日本からは、タイや韓国の病院で性別適合手術（SRS）や顔の女性化手術（FFS）を受ける人もいます。海外で受ける場合は、<strong>費用・言葉・術後のケア・渡航・戸籍変更に必要な書類</strong>など、国内とは違う注意点があります。手術の全体像は<a href="/surgery/">移行のための手術</a>を、海外渡航の段取りは信頼できる主治医や相談先と確認してください。掲載は紹介・推奨ではありません。
        </p>
        {overseasByCountry.map((group) => (
          <div class="finder-region">
            <h3 class="finder-region-name">{group.country}</h3>
            <ul class="finder-clinic-list">
              {group.items.map((clinic) => (
                <li class="finder-clinic">
                  <a href={`/clinics/${clinic.id}/`}>{clinic.name}</a>
                  <span class="finder-clinic-city">{clinic.city}</span>
                  {clinic.caps.length > 0 && (
                    <span class="finder-clinic-tags">
                      {clinic.caps.map((cap) => (
                        <span class:list={['clinic-tag', cap.startsWith('gaht') ? 'clinic-tag-gaht' : 'clinic-tag-surgery']}>
                          {CAPABILITY_LABELS[cap]}
                        </span>
                      ))}
                    </span>
                  )}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </section>
    )}

    <section aria-labelledby="faq">
      <h2 id="faq">よくある質問</h2>
      <dl class="finder-faq">
        {faqs.map((item) => (
          <div>
            <dt>{item.q}</dt>
            <dd>{item.a}</dd>
          </div>
        ))}
      </dl>
    </section>

    <nav class="word-chips entry-related" aria-label="関連ページ">
      <a class="word-chip" href="/clinics/">医療機関をさがす</a>
      <a class="word-chip" href="/surgery/">移行のための手術</a>
      <a class="word-chip" href="/cost/">お金のこと・費用</a>
      <a class="word-chip" href="/clinics/hormone-therapy/">ホルモン療法ができる病院</a>
      <a class="word-chip" href="/transition/">性別移行を知る</a>
    </nav>
  </article>
</BaseLayout>
