---
import BaseLayout from '../../layouts/BaseLayout.astro';
import clinicsData from '../../data/clinics.json';
import type { Clinic } from '../../types/clinic';
import { splitClinicUrls } from '../../utils/clinic-links';
import { capabilitiesOf, CAPABILITY_LABELS } from '../../utils/clinic-genre';

export function getStaticPaths() {
  const clinics = clinicsData as Clinic[];
  return clinics.map((clinic) => ({ params: { id: clinic.id }, props: { clinic } }));
}

const { clinic } = Astro.props as { clinic: Clinic };
const links = splitClinicUrls(clinic.urls);
const capabilities = capabilitiesOf(clinic);
const capLabels = capabilities.map((cap) => CAPABILITY_LABELS[cap]);
const canonical = new URL(`/clinics/${clinic.id}/`, Astro.site).toString();

// Location + documented services in the description, so long-tail searches like
// 「<県名> ホルモン療法 病院」/「MtF クリニック <地名>」can surface this page.
const place = [clinic.prefecture, clinic.city].filter(Boolean).join('');
const seoDescription =
  `${place}のトランスジェンダー対応の医療機関。`
  + (capLabels.length ? `${capLabels.join('・')}などの掲載情報。` : 'ホルモン療法など。')
  + '受診条件・費用・対応は変わることがあるため、必ず医療機関にご確認ください。';

// MedicalClinic structured data: factual (name, address, geo, telephone, the
// documented services) — not an endorsement or ranking, per the 掲載 policy.
const clinicLd = {
  '@context': 'https://schema.org',
  '@type': 'MedicalClinic',
  '@id': `${canonical}#clinic`,
  name: clinic.name,
  url: canonical,
  inLanguage: 'ja',
  ...(clinic.phone ? { telephone: clinic.phone } : {}),
  address: {
    '@type': 'PostalAddress',
    addressCountry: 'JP',
    addressRegion: clinic.prefecture,
    ...(clinic.city ? { addressLocality: clinic.city } : {}),
    ...(clinic.address ? { streetAddress: clinic.address } : {}),
  },
  ...(typeof clinic.lat === 'number' && typeof clinic.lng === 'number'
    ? { geo: { '@type': 'GeoCoordinates', latitude: clinic.lat, longitude: clinic.lng } }
    : {}),
  ...(links.officialUrls.length ? { sameAs: links.officialUrls } : {}),
  ...(capabilities.length
    ? {
        availableService: capabilities.map((cap) => ({
          '@type': cap.startsWith('gaht') ? 'MedicalTherapy' : 'MedicalProcedure',
          name: CAPABILITY_LABELS[cap],
        })),
      }
    : {}),
};
---

<BaseLayout title={`${clinic.name}（${clinic.prefecture}）- とらんすナビ`} description={seoDescription}>
  <script type="application/ld+json" set:html={JSON.stringify(clinicLd)} />
  <article class="article-shell">
    <div class="eyebrow">医療機関</div>
    <h1>{clinic.name}</h1>
    <p class="lead">{clinic.displayName}</p>

    {capabilities.length > 0 && (
      <ul class="clinic-tags" aria-label="公開情報で確認できた対応">
        {capabilities.map((cap) => (
          <li class:list={['clinic-tag', cap.startsWith('gaht') ? 'clinic-tag-gaht' : 'clinic-tag-surgery']}>
            {CAPABILITY_LABELS[cap]}
          </li>
        ))}
      </ul>
    )}
    <p class="clinic-tags-note">
      タグは、公開情報で確認できた対応です。<strong>タグがないことは、対応していないという意味ではありません。</strong>実際に受けられるかどうかは、かならず医療機関にご確認ください。
    </p>

    <dl class="clinic-detail">
      <div>
        <dt>地域</dt>
        <dd>{[clinic.prefecture, clinic.city].filter(Boolean).join(' / ')}</dd>
      </div>
      {clinic.address && (
        <div>
          <dt>住所</dt>
          <dd>{clinic.address}</dd>
        </div>
      )}
      {clinic.phone && (
        <div>
          <dt>電話</dt>
          <dd>{clinic.phone}</dd>
        </div>
      )}
      <div>
        <dt>掲載項目</dt>
        <dd>{clinic.services.join('、')}</dd>
      </div>
      <div>
        <dt>情報の確認</dt>
        <dd>{clinic.verificationStatus}</dd>
      </div>
      {links.officialUrls.length > 0 && (
        <div>
          <dt>公式サイト</dt>
          <dd>
            <ul>
              {links.officialUrls.map((url) => (
                <li><a href={url} target="_blank" rel="noreferrer">{url}</a></li>
              ))}
            </ul>
          </dd>
        </div>
      )}
      {links.relatedUrls.length > 0 && (
        <div>
          <dt>関連ページ</dt>
          <dd>
            <ul>
              {links.relatedUrls.map((url) => (
                <li><a href={url} target="_blank" rel="noreferrer">{url}</a></li>
              ))}
            </ul>
          </dd>
        </div>
      )}
    </dl>

    <section class="notice" aria-labelledby="clinic-warning">
      <h2 id="clinic-warning">受診前の確認</h2>
      <p>診療内容、費用、予約方法、診断書の要否は変わることがあります。受診前に必ず医療機関へ確認してください。このページは、特定の医療機関をすすめるものではありません。</p>
    </section>

    <section aria-labelledby="source-note">
      <h2 id="source-note">出典</h2>
      <p>{clinic.source.project} / {clinic.source.path}（{clinic.source.license}）。取り込み元に口コミ、体験談、主観的評価が含まれる場合も、医療機関ページには確認できる項目を優先して掲載しています。</p>
    </section>
  </article>
</BaseLayout>
