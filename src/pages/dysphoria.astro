---
import BaseLayout from '../layouts/BaseLayout.astro';
import References from '../components/References.astro';
import Cite from '../components/Cite.astro';

// Link the deeper explanations to the Japanese translation of The Gender
// Dysphoria Bible (a community preview hosted at bible.transnavi.jp; the JA
// chapter slugs are the same words as kind.name). The original is CC BY-NC-SA.
const GDB_JA = 'https://bible.transnavi.jp/ja';

// 違和のいろいろな形。説明は当サイトで独自に書き、詳しい解説は
// The Gender Dysphoria Bible（CC BY-NC-SA）の日本語訳へリンクしています。
const kinds = [
  { name: '身体的違和', en: 'physical-dysphoria',
    body: '自分のからだの特徴（体つき、声、毛、胸、性器など）に対して感じる違和。鏡を見たくない、写真がつらい、といった形でも現れます。' },
  { name: '生化学的違和', en: 'biochemical-dysphoria',
    body: '体内のホルモンのバランスそのものに根ざした、言葉にしにくい不快感や落ち着かなさ。ホルモン療法で和らぐことがあります。' },
  { name: '対人的違和', en: 'social-dysphoria',
    body: '人とのやり取りの中で、ちがう性別として扱われること（呼ばれ方、見られ方、「くん／さん」など）から生じる違和。' },
  { name: '社会的違和', en: 'societal-dysphoria',
    body: '制度や書類、世の中の「ふつう」や期待といった、より大きな枠組みから生じる違和。自分のせいではありません。' },
  { name: '性的違和', en: 'sexual-dysphoria',
    body: '性的な場面や親密な関係の中で生じる違和。からだや役割への違和感として現れることがあります。' },
  { name: '表現的違和', en: 'presentational-dysphoria',
    body: 'ファッション・服装・髪型・メイクなど、自分をどう見せるか（性別表現）にまつわる違和。「らしく」させられることのつらさ。' },
  { name: '実存的違和', en: 'existential-dysphoria',
    body: '自分の存在や将来そのものに向けられる、より深い違和。「この先どう生きていくのか」という不安として現れることも。' },
  { name: '管理された違和', en: 'managed-dysphoria',
    body: '違和を抑え込み、「やり過ごしてきた」状態。慣れて感じにくくなっていることもありますが、それは消えたのとは違います。' },
];
---

<BaseLayout
  title="性別違和を知る - とらんすナビ"
  description="性別違和（ジェンダー・ディスフォリア）とは何か、どんな形で現れるのか。性同一性障害（GID）・性別不合（GI）・性別違和（GD）の違いや、違和のいろいろなかたち、その対極にある性別高揚感まで。"
>
  <article class="article-shell">
    <div class="eyebrow">知る</div>
    <h1>性別違和を知る</h1>
    <p class="lead">
      「性別違和」は、出生時に割り当てられた性別と、自分が感じている性別とのあいだのズレから生じる、苦しさや違和感のことです。現れ方も強さも、人によってずいぶん違います。
    </p>

    <section aria-labelledby="what-heading">
      <h2 id="what-heading">性別違和（ジェンダー・ディスフォリア）とは</h2>
      <p>
        <a href="/glossary/gender-dysphoria/">性別違和</a>は「病気」や「弱さ」ではありません。<Cite src="nhs-gd">自分の性のあり方と、まわりから期待される性別とが食い違うときに、心やからだが感じる自然な反応です</Cite>。
      </p>
      <p>
        大切なのは、<strong>「これくらい違和があればトランス」という線引きはない</strong>ということ。違和が強くなくてもトランスジェンダーでありえますし、感じ方は時期によっても変わります。全部に当てはまる必要も、強く感じる必要もありません。「トランスであるには性別違和が必要だ」とする考え方（<a href="/glossary/transmedicalism/">トランスメディカリズム</a>）もありますが、当事者のあいだでも意見が分かれており、絶対のものではありません。
      </p>
      <p>
        このサイトでは、性別違和を「出生時に割り当てられた性別と、自分の性のあり方とのあいだのズレ」という、広い意味でとらえています。そのズレが、あなたにとってどんなかたちで現れていても（言葉にしにくくても、強くなくても、男女の枠の内でも外でも）、<strong>あなたがトランスジェンダーを名乗ることは、正当なことです。</strong>
      </p>
      <p>
        臨床的には、<Cite src={['th-gd-review', 'who-icd11', 'matsunaga-icd11']}>DSM-5 で「性別違和」、ICD-11 で「<a href="/glossary/gender-incongruence/">性別不合</a>」と呼ばれます</Cite>。<Cite src="jspn-guideline">かつての「性同一性障害」という言い方は、今は使われなくなってきています</Cite>。
      </p>
    </section>

    <section aria-labelledby="names-heading">
      <h2 id="names-heading">名前のこと（GID・GD・GI・トランスジェンダー）</h2>
      <p>
        この分野には、にた言葉がいくつもあって、ややこしく感じられます。関係を整理しておきます。
      </p>
      <ul class="assure-list">
        <li><strong><a href="/glossary/transgender/">トランスジェンダー</a></strong>は、医学の診断名ではなく、生き方やアイデンティティを表す<strong>総称</strong>です。出生時に割り当てられた性別と<a href="/glossary/gender-identity/">性同一性</a>が違えば、トランスジェンダー。<a href="/glossary/transgender-woman/">トランス女性</a>を MtF、<a href="/glossary/transgender-man/">トランス男性</a>を FtM と呼ぶこともあります（やや古い言い方です）。</li>
        <li><strong>性同一性障害（GID）</strong>は、<Cite src="matsunaga-icd11">古い医学の診断名で、国際的にはここ十年あまりで見直され、使われなくなりました</Cite>。日本では特例法などの関係で、いまも専門的な名前としていちばん知られています。「性同一性（こころの性）そのものが障害」であるかのように聞こえるため、適切ではないとされました。</li>
        <li>GIDに代わったのが、<strong><a href="/glossary/gender-incongruence/">性別不合</a>（GI）</strong>と<strong><a href="/glossary/gender-dysphoria/">性別違和</a>（GD）</strong>です。トランスであること自体は病気ではない、という考え方のもとで、<Cite src="who-icd11">性別不合（GI）は ICD-11 で「性の健康に関連する状態」とされ、精神疾患ではなくなりました</Cite>。性別違和（GD）は、性別のズレから生じる<strong>苦痛や違和感</strong>に焦点をあてた診断名です。</li>
      </ul>
      <p>
        <Cite src="th-gd-review">アメリカ精神医学会の診断基準（DSM）でも、第3版（1980）の「性転換症」、第4版（1994）の「性同一性障害」、第5版（2013）の「性別違和」と、医学の進み方にあわせて名前が変わってきました</Cite>。
      </p>
      <p>
        名前は変わっても、トランスの人の苦痛を受けとめ、ケアにつなげるための診断という意味では<strong>つながっている</strong>ものです。ただ、名前が変わってきた背景には、「トランスであること自体は病気ではない」という考え方の変化があります。だから、GID と、GI・GD は<strong>まったく同じ意味ではありません</strong>（GI は精神疾患ではなく、GD は苦痛に焦点をあてた診断です）。どの名前で呼ばれても、あなたの感じていることが、軽くなったり重くなったりするわけではありません。
      </p>
    </section>

    <section aria-labelledby="universal-heading">
      <h2 id="universal-heading">トランスの人だけのものではありません</h2>
      <p>
        性別違和に似た感覚は、じつは<a href="/glossary/cisgender/">シスジェンダー</a>の人にも起こりえます。シス男性でも、シス女性でも起こります。たとえば、こんなときです。
      </p>
      <ul class="assure-list">
        <li>ホルモンバランスの乱れなどで、体つき・体毛・声などが「その性別の典型」から外れたとき（シス男性の女性化乳房や薄毛、シス女性の多毛や声の低さなど）。</li>
        <li>体毛、身長、胸の大きさといった見た目が、自分の性別に「期待されるもの」と違うことへの、落ち着かなさ。</li>
        <li>そして、自分の望まない性別として扱われ、その役割で生きるよう求められてきたとき。</li>
      </ul>
      <p>
        つまり、性別違和は人間に広くありうる感覚です。トランスの人は、それをより強く、長く感じています。そう考えると、<strong>あなたが感じていることは、特別で異常なことではない</strong>とわかってもらえるかもしれません。
      </p>
    </section>

    <section aria-labelledby="hindsight-heading">
      <h2 id="hindsight-heading">気づくのは、あとからかもしれません</h2>
      <p>
        性別違和は、自分ではっきり気づくのが、意外とむずかしいものです。多くのトランスの人が、移行を始めてみて初めて「ああ、あの長いあいだの生きづらさや自信のなさは、これだったのか」と気づきます。
      </p>
      <p>
        気づくタイミングは、本当に人それぞれです。ことばを覚えるころにはわかっていた子もいれば、思春期に入って初めて感じる人、大人になるまで「何かが違う」とまったく気づかなかった人もいます。そもそも「自分の性別は、生まれたときに決められたものと違うかもしれない」という見方に出会う機会がなく、ただ受け入れて生きてきた人も、少なくありません。メディアで語られる「幼いころから、自分は本当は女の子（男の子）だと確信していた」という物語は、数あるかたちのひとつにすぎません。それに当てはまらなくても、これまで自分の違和を「トランスの人が感じるものとは別だ」と思っていたとしても、なにもおかしくありません。
      </p>
      <p>
        ずっと当たり前だと思ってきた、漠然とした違和感、なんとなくの不安、自分へのうまく説明できない自信のなさ。そうしたものが、じつは性別違和から来ていたと、あとからわかることがあります。だから「自分に性別違和があるのか、よくわからない」と感じても、まったくおかしくありません。
      </p>
      <p>
        ひとつの目安があります。もし、自分の性別や「自分とは何者なのか」について、<strong>毎日のように考えてしまっている</strong>なら、あなたはたぶん、自分で思っているほど「自分には関係ない（<a href="/glossary/cisgender/">シス</a>だ）」とは言いきれないのかもしれません。多くのシスジェンダーの人は、自分の性別について、そこまで考え続けたりはしないからです。
      </p>
      <p>
        子どものころや思春期には、違和はことばより先に、気分や態度として表れることがあります。二次性徴（声変わり、胸のふくらみ、月経、ひげなど）が近づくと強い不安や抵抗を感じる、自分の体の変化を見たくない、といった形をとることも少なくありません。うまく説明できなくても、その感覚は本物です。
      </p>
      <p>
        答えを急ぐ必要はありません。ただ、その問いを抱えていること自体を、どうか否定しないであげてください。
      </p>
    </section>

    <section aria-labelledby="kinds-heading">
      <h2 id="kinds-heading">違和には、いろいろな形がある</h2>
      <p class="resource-section-intro">
        性別違和はひとつの感覚ではなく、いくつもの面から現れます。自分の気持ちに名前がつくと、少し整理しやすくなることがあります。
      </p>
      <div class="concept-grid">
        {kinds.map((kind) => (
          <div class="concept-card">
            <h3>{kind.name}</h3>
            <p>{kind.body}</p>
            <a class="concept-more" href={`${GDB_JA}/${kind.name}/`} target="_blank" rel="noreferrer">くわしく（日本語訳）→</a>
          </div>
        ))}
      </div>
    </section>

    <section aria-labelledby="euphoria-heading">
      <h2 id="euphoria-heading">性別高揚感（ジェンダー・ユーフォリア）</h2>
      <p>
        違和の「対極」にあるのが、<strong>性別高揚感</strong>です。<Cite src={['euphoria-jacobsen', 'ges-scale']}>自分の性同一性が肯定されたとき（望む名前で呼ばれた、しっくりくる服を着られた、など）にわいてくる、ほっとする喜びのこと</Cite>です。
      </p>
      <p>
        つらさ（違和）よりも先に、この喜びのほうから自分に気づく人もいます。「何が苦しいか」だけでなく「何が心地よいか」も、自分を知る手がかりになります。
        <a href={`${GDB_JA}/性別高揚感/`} target="_blank" rel="noreferrer">くわしく（日本語訳）→</a>
      </p>
    </section>

    <aside class="entry-message" role="note" aria-label="読んでいるあなたへ">
      <p>「自分は本物のトランスではないのかも」と感じても、大丈夫。その迷いは、とても多くの人が通る道です。何かの基準を満たさないと当事者になれない、ということはありません。<a href={`${GDB_JA}/インポスター症候群/`} target="_blank" rel="noreferrer">（インポスター症候群について・日本語訳）</a></p>
    </aside>

    <nav class="word-chips entry-related" aria-label="関連ページ">
      <a class="word-chip" href="/basics/">トランス・シス・ノンバイナリーって？</a>
      <a class="word-chip" href="/transition/">性別移行を知る</a>
      <a class="word-chip" href="/gender/">性別は、男女だけじゃない</a>
      <a class="word-chip" href="/glossary/">用語集</a>
      <a class="word-chip" href="/support/">相談先</a>
    </nav>

    <p class="source-note">
      「違和のいろいろな形」という整理は、
      {' '}<a href="https://genderdysphoria.fyi/" target="_blank" rel="noreferrer">The Gender Dysphoria Bible（性別違和バイブル）</a>
      （Jocelyn Badgley ほか、CC BY-NC-SA）を参考にしています。本ページの文章は当サイトが独自に書いたものです。各項目の「くわしく」は、有志による
      {' '}<a href="https://bible.transnavi.jp/ja/" target="_blank" rel="noreferrer">日本語訳（プレビュー版）</a>
      にリンクしています（原文は上記サイト。今後、本家への反映を予定しています）。
    </p>
    <References route="/dysphoria/" />
  </article>
</BaseLayout>
